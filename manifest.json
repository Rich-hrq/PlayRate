{
  "manifest_version": 3,
  "name": "PlayRate",
  "version": "1.0.0",
  "description": "Control video playback speed — 2.5x, 3x, 3.5x, 4x and custom speeds",
  "action": {
    "default_popup": "popup.html",
    "default_title": "PlayRate — Video Speed Controller"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
